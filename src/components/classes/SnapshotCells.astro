---
import rubric from "../../assets/data/rubric.json";

interface Props {
  executed_cell_id: string;
  snapshot: { cell_type: string; source: string; cell_id: string }[];
  prompt: string;
}

const { snapshot, executed_cell_id, prompt } = Astro.props;

const puzzle = rubric.puzzles.find((p) => p.name === prompt);

const relevantFields: string[] = puzzle
  ? [...new Set(puzzle.signals.flatMap((s) => s.relevant_fields))]
  : [];

const markSet: string[] = puzzle
  ? [
      ...new Set(
        puzzle.signals.flatMap((s) =>
          s.markset.map((m) => m.mark.toLowerCase()),
        ),
      ),
    ]
  : [];
---

<div class="flow w-full">
  {
    snapshot.map((cell) => {
      const isExecuted = cell.cell_id === executed_cell_id;
      return (
        <div
          data-cell-id={cell.cell_id}
          data-executed={isExecuted}
          class:list={[
            "w-full border-3 rounded-none p-2",
            isExecuted
              ? "border-[#9AD9EB] bg-[#F0FBFD]"
              : "border-[#EEEEEE] bg-[#FFFFF9]",
          ]}
        >
          <div class="flex gap-2 w-full">
            {/* <div class="flex-shrink-0 flex items-start justify-center pt-1"></div> */}
            <div
              class="read-only-editor w-full overflow-x-auto"
              data-source={cell.source}
              data-relevant-fields={JSON.stringify(relevantFields)}
              data-mark-set={JSON.stringify(markSet)}
            />
          </div>
        </div>
      );
    })
  }
</div>

<script>
  import { EditorView, basicSetup } from "codemirror";
  import { python } from "@codemirror/lang-python";
  import { Decoration, ViewPlugin } from "@codemirror/view";
  import type { DecorationSet } from "@codemirror/view";
  import { RangeSetBuilder } from "@codemirror/state";

  function makeHighlightPlugin(relevantFields: string[], markSet: string[]) {
    const terms = [...markSet, ...relevantFields].sort(
      (a, b) => b.length - a.length,
    );

    if (terms.length === 0) {
      return ViewPlugin.fromClass(class {});
    }

    const fieldSet = new Set(relevantFields.map((f) => f.toLowerCase()));
    const markSetLower = new Set(markSet.map((m) => m.toLowerCase()));

    const pattern = new RegExp(
      `\\b(${terms.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|")})\\b`,
      "gi",
    );

    const fieldMark = Decoration.mark({ class: "cm-highlight-field" });
    const markTypeMark = Decoration.mark({ class: "cm-highlight-mark" });

    return ViewPlugin.fromClass(
      class {
        decorations: DecorationSet;

        constructor(view: EditorView) {
          this.decorations = this.buildDecorations(view);
        }

        update(update: { docChanged: boolean; view: EditorView }) {
          if (update.docChanged) {
            this.decorations = this.buildDecorations(update.view);
          }
        }

        buildDecorations(view: EditorView): DecorationSet {
          const builder = new RangeSetBuilder<Decoration>();
          const doc = view.state.doc.toString();

          const matches: { from: number; to: number; term: string }[] = [];
          let match: RegExpExecArray | null;
          pattern.lastIndex = 0;

          while ((match = pattern.exec(doc)) !== null) {
            matches.push({
              from: match.index,
              to: match.index + match[0].length,
              term: match[0].toLowerCase(),
            });
          }

          // RangeSetBuilder requires ranges sorted by `from`
          matches.sort((a, b) => a.from - b.from);

          for (const { from, to, term } of matches) {
            const decoration = fieldSet.has(term) ? fieldMark : markTypeMark;
            builder.add(from, to, decoration);
          }

          return builder.finish();
        }
      },
      { decorations: (v) => v.decorations },
    );
  }

  function initEditors(root: Document | HTMLElement = document) {
    root.querySelectorAll<HTMLElement>(".read-only-editor").forEach((el) => {
      // guard against double-initialization if HTMX ever re-processes a node
      if (el.dataset.initialized) return;
      el.dataset.initialized = "true";

      const source = (JSON.parse(el.dataset.source ?? "[]") as string[]).join(
        "\n",
      );
      const relevantFields: string[] = JSON.parse(
        el.dataset.relevantFields ?? "[]",
      );
      const markSet: string[] = JSON.parse(el.dataset.markSet ?? "[]");

      new EditorView({
        doc: source,
        extensions: [
          basicSetup,
          python(),
          EditorView.editable.of(false),
          EditorView.theme({
            "&": { fontSize: "12px" },
            ".cm-highlight-field": {
              backgroundColor: "#FAEEDA",
              color: "#633806",
              borderRadius: "2px",
              padding: "0 1px",
            },
            ".cm-highlight-mark": {
              backgroundColor: "#EEEDFE",
              color: "#3C3489",
              borderRadius: "2px",
              padding: "0 1px",
            },
            ".cm-scroller": { fontFamily: "var(--font-mono, monospace)" },
            ".cm-gutters": { display: "none" },
            ".cm-cursor": { display: "none" },
          }),
          makeHighlightPlugin(relevantFields, markSet),
        ],
        parent: el,
      });
    });
  }

  initEditors();

  document.addEventListener("htmx:afterSwap", (e) => {
    const target = (e as CustomEvent).detail.target as HTMLElement;
    initEditors(target);
  });
</script>
