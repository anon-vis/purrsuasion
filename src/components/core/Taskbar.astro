---
import { assertStudent } from "../../lib/core/utils";

assertStudent(Astro.locals);

interface Props {
  ableToJudge: boolean;
}

const { ableToJudge } = Astro.props;
const { isReceiver, condensedPrompt, roundStarted, prompt } = Astro.locals;

const borderStyle = isReceiver
  ? "border-b-pink border-r-pink"
  : "border-b-blue border-r-blue";

const buttonStyle =
  "hover:scale-105 font-bold btn border-3 border-l-[white] border-t-[white] border-r-[#838585] border-b-[#838585] bg-[#c3c3c3] text-black btn-square rounded-none";
---

<div
  hx-trigger="sse:able_to_judge"
  hx-get={`/student/able-to-judge`}
  hx-target="#whisker_sign_btn"
  hx-swap="outerHTML"
  class="repel items-center bg-[#DDDDDD] w-full border-t-4 border-[#c3c3c3] absolute top-[calc(100vh_-_80px)] h-[80px] px-12 py-4"
>
  <div class="flex gap-4">
    <button
      class={`btn btn-square rounded-none border-3  ${buttonStyle}`}
      onclick="meow_mail.show()"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect
          x="2"
          y="4"
          width="20"
          height="16"
          rx="2"></rect></svg
      >
    </button>

    {
      !isReceiver && (
        <button
          class={`btn btn-square rounded-none border-3 ${buttonStyle}`}
          onclick="cat_plot.show()"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <>
              <path d="M3 3v16a2 2 0 0 0 2 2h16" />
              <path d="m19 9-5 5-4-4-3 3" />
            </>
          </svg>
        </button>
      )
    }

    {
      isReceiver && (
        <button
          id="whisker_sign_btn"
          disabled={!ableToJudge}
          class={`btn btn-square rounded-none border-3 ${buttonStyle}`}
          onclick="whisker_sign.show()"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-signature-icon lucide-signature"
          >
            <>
              <path d="m21 17-2.156-1.868A.5.5 0 0 0 18 15.5v.5a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1c0-2.545-3.991-3.97-8.5-4a1 1 0 0 0 0 5c4.153 0 4.745-11.295 5.708-13.5a2.5 2.5 0 1 1 3.31 3.284" />
              <path d="M3 21h18" />
            </>
          </svg>
        </button>
      )
    }
  </div>

  <div
    role="button"
    data-tip={prompt}
    class={`border-3 tooltip ${isReceiver ? "border-pink" : "border-blue"} bg-[#FFFFF9] p-2`}
  >
    Objective: {condensedPrompt}
  </div>

  <div class="flex gap-2 items-center">
    <div
      id="timer"
      data-round-started={roundStarted}
      class={`w-[75px] text-center border-4 font-bold px-1 py-1 bg-[#FFFFF9] border-t-[#c3c3c3] border-l-[#c3c3c3] ${borderStyle}`}
    >
      25:00
    </div>
    <span
      class={`btn btn-square rounded-none border-3 ${buttonStyle}`}
      hx-target="this"
      hx-post="/api/logout"
      ><svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="m16 17 5-5-5-5"></path><path d="M21 12H9"></path><path
          d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg
      ></span
    >
  </div>
</div>

<script>
  const timerEl = document.getElementById("timer")!;
  const roundStarted = new Date(timerEl.dataset.roundStarted!).getTime();
  const duration = 25 * 60 * 1000; // 25 minutes in milliseconds

  function updateTimer() {
    const now = Date.now();
    const elapsed = now - roundStarted;
    const remaining = Math.max(0, duration - elapsed);

    const minutes = Math.floor(remaining / 60000);
    const seconds = Math.floor((remaining % 60000) / 1000);

    const formattedTime = `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
    timerEl.textContent = formattedTime;

    if (remaining > 0) {
      requestAnimationFrame(updateTimer);
    }
  }

  updateTimer();
</script>
