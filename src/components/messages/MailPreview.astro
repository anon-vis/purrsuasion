---
import type { Message } from "../../lib/models";
import { assertStudent } from "../../lib/core/utils";

assertStudent(Astro.locals);

interface Props {
  message: Message;
  isSelected: boolean;
  isNew: boolean;
}

const { message, isSelected, isNew } = Astro.props;
const { groupMembers } = Astro.locals;
---

<li
  id={`message-${message.id}`}
  hx-trigger="click"
  hx-include="[name='selected']"
  hx-get={`/student/messages/thread?roundId=${message.round_id}&from=${message.user_id}&which=all`}
  hx-target="#msg-thread"
  hx-swap="innerHTML"
  class={`${isSelected ? "bg-gray-200" : "bg-gray-50"} indicator hover:bg-gray-200 w-[200px] relative border-gray-200 border-3 flex cursor-pointer text-sm px-5 py-3 items-center justify-between`}
>
  {isNew && <span class="indicator-item status status-success" />}

  <div class="flex flex-col w-max">
    <div>{groupMembers.find((u) => u.id === message.user_id)?.username}</div>
    <div class="truncate w-[70px]">
      {message.subject}
    </div>
  </div>

  <div class="w-max text-sm">
    {
      new Date(message.timestamp).toLocaleTimeString([], {
        hour: "numeric",
        minute: "2-digit",
      })
    }
  </div>
</li>
