---
import z from "zod";
import { userService } from "../../../lib/services/";

export const prerender = false;
export const partial = true;

if (Astro.request.method !== "PATCH") {
  return Astro.redirect(null, 404);
}

const formData = await Astro.request.formData();

const parsed = z
  .object({
    id: z.coerce.number(),
    is_consented: z.coerce.number(),
  })
  .safeParse({
    id: formData.get("id"),
    is_consented: formData.get("is_consented"),
  });

console.log(parsed);

if (parsed.success) {
  userService.toggleConsented(parsed.data.id);
} else {
  console.log(parsed.error);
}
---

{
  parsed.success && parsed.data.is_consented === 1 && (
    <button
      class="btn btn-warning"
      hx-target="this"
      hx-patch="/admin/students/toggle-consent"
      hx-swap="outerHTML"
      hx-vals={`{"id": ${parsed.data.id}, "is_consented": ${parsed.data.is_consented ? 0 : 1}}`}
    >
      unconsent
    </button>
  )
}

{
  parsed.success && !parsed.data.is_consented && (
    <button
      class="btn"
      hx-patch="/admin/students/toggle-consent"
      hx-swap="outerHTML"
      hx-vals={`{"id": ${parsed.data.id}, "is_consented": ${!parsed.data.is_consented ? 1 : 0}}`}
    >
      consent
    </button>
  )
}
