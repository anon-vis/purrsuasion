---
import { Result } from "neverthrow";
import z from "zod";
import { classService } from "../../../lib/services/index";
import type { DomainError } from "../../../lib/models";
import SenderList from "../../../components/classes/SenderList.astro";

export const prerender = false;
export const partial = true;

const parsedClassId = z.coerce
  .number()
  .safeParse(Astro.url.searchParams.get("classId"));
const parsedPrompt = z.string().safeParse(Astro.url.searchParams.get("prompt"));

let senderList: Result<{ user_id: number }[], DomainError>;

if (parsedClassId.success && parsedPrompt.success) {
  senderList = classService.getStudentsWhoCompletedPuzzle(
    parsedClassId.data,
    parsedPrompt.data,
  );
} else {
  return Astro.redirect("/");
}
---

{
  senderList && senderList.isOk() && senderList.value.length > 0 && (
    <SenderList prompt={parsedPrompt.data} senders={senderList.value} />
  )
}

{
  senderList && senderList.isOk() && senderList.value.length === 0 && (
    <div>No students completed puzzle.</div>
  )
}

<div id="sender-visualizations" hx-swap-oob="innerHTML">
  <h3>Visualizations</h3>
  <p>Select a student to view visualizations.</p>
</div>

<div id="sender-snapshots" hx-swap-oob="innerHTML">
  <h3>Notebook Snapshot</h3>
  <p>Select a viz to view snapshot.</p>
</div>

<div id="rubric" hx-swap-oob="innerHTML">
  <h3>Rubric</h3>
  <p>Select a viz to view relevant heuristics.</p>
</div>
