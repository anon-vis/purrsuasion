---
import MailForm from "../../../components/messages/MailForm.astro";
import { assertStudent } from "../../../lib/core/utils";
assertStudent(Astro.locals);

export const prerender = false;
export const partial = true;

const from = Astro.locals.id;
const groupId = +Astro.url.searchParams.get("groupId")!;
const roundId = +Astro.url.searchParams.get("roundId")!;

const buttonStyle = Astro.locals.isReceiver
  ? "hover:bg-pink border-pink"
  : "hover:bg-blue border-blue";
---

<MailForm from={from} />

<button
  disabled
  id="draft-btn"
  class={`${buttonStyle} text-[#838585] rounded-none border-0 bg-white btn btn-sm`}
  hx-target="#msg-thread"
  hx-swap-oob="true"
  hx-get={`/student/messages/draft?groupId=${groupId}&roundId=${roundId}`}
>
  NEW MAIL
</button>
